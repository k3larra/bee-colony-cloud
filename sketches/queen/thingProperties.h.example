// Copy this file to thingProperties.h and replace the placeholders
// with the values generated for the specific Arduino Cloud Thing/device.

#pragma once

#include <ArduinoIoTCloud.h>
#include <Arduino_ConnectionHandler.h>

const char DEVICE_LOGIN_NAME[] = "REPLACE_WITH_DEVICE_LOGIN_NAME";

const char SSID[] = SECRET_SSID;
const char PASS[] = SECRET_OPTIONAL_PASS;
const char DEVICE_KEY[] = SECRET_DEVICE_KEY;

void onDesiredModeChange();
void onMinStoreThresholdChange();
void onTargetWorkerEffortChange();

String desired_mode;
String firmware_version;
String queen_health;
int min_store_threshold;
int target_worker_effort;

void initProperties() {
  ArduinoCloud.setBoardId(DEVICE_LOGIN_NAME);
  ArduinoCloud.setSecretDeviceKey(DEVICE_KEY);
  ArduinoCloud.addProperty(desired_mode, READWRITE, ON_CHANGE, onDesiredModeChange);
  ArduinoCloud.addProperty(firmware_version, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(queen_health, READ, ON_CHANGE, NULL);
  ArduinoCloud.addProperty(min_store_threshold, READWRITE, ON_CHANGE, onMinStoreThresholdChange);
  ArduinoCloud.addProperty(target_worker_effort, READWRITE, ON_CHANGE, onTargetWorkerEffortChange);
}

WiFiConnectionHandler ArduinoIoTPreferredConnection(SSID, PASS);
